# --- Pipeline outputs (regenerated by main.py) ---
# Trainer scratch dir.
results/
# Generated figures and tables. Commented out by default so that the
# committed sample artifacts (from scripts/generate_sample_artifacts.py)
# remain visible in the repo. Uncomment if you don't want generated
# outputs tracked by git.
# figures/*.svg
# figures/*.png
# figures/*.pdf
# tables/*.json
# tables/*.csv
# Legacy (results used to be flat; keep for repos that still have these).
results_*.json
per_fold_*.csv
cross_model_*.json
cross_model_*.csv
fig*.png
tmp_*/

