# Copy this file to `.env` and adjust the values for your machine.
# `.env` is gitignored so secrets stay local.

# Path to the labeled bug-pattern JSON (must contain a `bug_category` field
# with values "classical" or "quantum" on each labeled record).
DATA_PATH=data/bug_patterns_labeled.json

# Trainer scratch directory: per-fold temp dirs live here and are removed
# at the end of every fold. Safe to gitignore.
OUTPUT_DIR=results

# PNG figures (per-model + cross-model).
FIGURES_DIR=figures

# CSV / JSON result tables (per-model + cross-model).
TABLES_DIR=tables

# Optional HuggingFace cache override (useful when running on shared GPUs).
# HF_HOME=.cache/huggingface

# Optional: HuggingFace access token (only needed for gated models — none of
# the three backbones in this project require it).
# HF_TOKEN=
